#!/usr/bin/env bash
set -euo pipefail

service_user="dasobjectstore"
service_group="dasobjectstore"
admin_group="dasobjectstore-admin"
managed_root="/srv/dasobjectstore"
product_root="/opt/dasobjectstore"

ensure_group() {
  if ! getent group "$service_group" >/dev/null; then
    groupadd --system "$service_group"
  fi
  if ! getent group "$admin_group" >/dev/null; then
    groupadd --system "$admin_group"
  fi
}

ensure_user() {
  if ! id -u "$service_user" >/dev/null 2>&1; then
    useradd --system \
      --gid "$service_group" \
      --home-dir /var/lib/dasobjectstore \
      --no-create-home \
      --shell /usr/sbin/nologin \
      "$service_user"
  fi
}

ensure_container_runtime_access() {
  if getent group docker >/dev/null; then
    usermod -aG docker "$service_user"
  else
    cat >&2 <<WARNING
DASObjectStore formal PDF reporting requires access to the Docker API, but the
docker group does not exist. Install or repair Docker, then add $service_user to
the docker group and restart dasobjectstore-server.service.
WARNING
  fi
}

ensure_web_admin_peer_membership() {
  usermod -aG "$admin_group" "$service_user"
}

ensure_report_provider() {
  local wrapper="/usr/libexec/dasobjectstore/gnostikon-workflow-control"
  if [[ ! -x "$wrapper" ]]; then
    return 0
  fi

  if "$wrapper" prewarm-report-provider >/dev/null 2>&1; then
    printf 'DASObjectStore formal PDF report provider is installed and prewarmed.\n'
    return 0
  fi

  cat >&2 <<WARNING
DASObjectStore formal PDF reporting could not prewarm the Grammateus provider.
Install or repair Grammateus and initialise the provider with:
  grammateus_report_provider install --image grammateus/report:0.8.1
Then restart dasobjectstore-server.service before rebuilding reports from the
Web interface.
WARNING
}

ensure_owned_dir() {
  local path="$1"
  local mode="$2"
  install -d -o "$service_user" -g "$service_group" -m "$mode" "$path"
}

repair_managed_tree() {
  local root="$1"
  if [[ ! -d "$root" ]]; then
    return 0
  fi

  chown "$service_user:$service_group" "$root"
  chmod 0750 "$root"
  find "$root" -mindepth 1 \
    -path "$root/lost+found" -prune \
    -o -exec chown "$service_user:$service_group" {} +
  find "$root" \
    -path "$root/lost+found" -prune \
    -o -type d -exec chmod 0750 {} +
  find "$root" \
    -path "$root/lost+found" -prune \
    -o -type f -exec chmod 0640 {} +
}

repair_marked_managed_tree() {
  local root="$1"
  if [[ ! -d "$root" ]]; then
    return 0
  fi
  if [[ ! -d "$root/.dasobjectstore" ]]; then
    cat >&2 <<WARNING
DASObjectStore left existing files below $root untouched because the profile
namespace marker is missing. Explicit profile adoption/reconciliation is
required before package configuration can manage that tree.
WARNING
    return 0
  fi
  repair_managed_tree "$root"
}

ensure_profile_layout() {
  local root="$1"
  ensure_owned_dir "$root" 0750
  if [[ -e "$root/ssd" && ! -d "$root/ssd" ]]; then
    printf 'DASObjectStore profile path %s/ssd is not a directory.\n' "$root" >&2
    exit 1
  fi
  if [[ -e "$root/hdd" && ! -d "$root/hdd" ]]; then
    printf 'DASObjectStore profile path %s/hdd is not a directory.\n' "$root" >&2
    exit 1
  fi
  if [[ ! -e "$root/ssd" ]]; then
    ensure_owned_dir "$root/ssd" 0750
  fi
  if [[ ! -e "$root/hdd" ]]; then
    install -d -o root -g root -m 0755 "$root/hdd"
  fi
}

reject_user_owned_managed_root() {
  local path="$1"
  if [[ ! -e "$path" ]]; then
    return 0
  fi

  local owner group
  owner="$(stat -c '%U' "$path")"
  group="$(stat -c '%G' "$path")"
  if [[ "$owner" != "$service_user" || "$group" != "$service_group" ]]; then
    cat >&2 <<ERROR
DASObjectStore managed root $path is owned by $owner:$group.
Managed DAS roots must be owned by $service_user:$service_group so normal users
submit jobs through dasobjectstored instead of writing directly to member disks.
Repair ownership with the formal DASObjectStore disk lockdown command before
continuing package configuration.
ERROR
    exit 1
  fi
}

ensure_group
ensure_user
ensure_web_admin_peer_membership
ensure_container_runtime_access

ensure_owned_dir /run/dasobjectstore 0750
ensure_owned_dir /var/lib/dasobjectstore 0750
ensure_owned_dir /var/lib/dasobjectstore/object-service 0700
ensure_owned_dir /var/lib/dasobjectstore/report-rebuild 0750
ensure_owned_dir /var/lib/dasobjectstore/telemetry 0750
ensure_owned_dir /var/log/dasobjectstore 0750
ensure_owned_dir "$product_root" 0750
ensure_owned_dir "$product_root/tls" 0750
install -d -o root -g "$service_group" -m 0750 /etc/dasobjectstore
find /etc/dasobjectstore -maxdepth 1 -type f -name '*.json' \
  -exec chgrp "$service_group" {} + \
  -exec chmod 0640 {} +
store_registry_state=/var/lib/dasobjectstore/stores.json
store_registry_config=/etc/dasobjectstore/stores.json
if [[ ! -e "$store_registry_state" && -f "$store_registry_config" ]]; then
  install -o "$service_user" -g "$service_group" -m 0640 \
    "$store_registry_config" "$store_registry_state"
elif [[ -f "$store_registry_state" ]]; then
  chown "$service_user:$service_group" "$store_registry_state"
  chmod 0640 "$store_registry_state"
fi
if [[ -f "$product_root/config.json" ]]; then
  chown root:"$service_group" "$product_root/config.json"
  chmod 0640 "$product_root/config.json"
fi
if [[ -f /usr/libexec/dasobjectstore/dasobjectstore-local-auth-helper ]]; then
  chown root:"$service_group" /usr/libexec/dasobjectstore/dasobjectstore-local-auth-helper
  chmod 4750 /usr/libexec/dasobjectstore/dasobjectstore-local-auth-helper
fi

reject_user_owned_managed_root "$managed_root"
ensure_profile_layout "$managed_root"
repair_marked_managed_tree "$managed_root/ssd"
if [[ -d "$managed_root/hdd" ]]; then
  chown root:root "$managed_root/hdd"
  chmod 0755 "$managed_root/hdd"
  for root in "$managed_root"/hdd/*; do
    repair_marked_managed_tree "$root"
  done
fi

if [[ -x /usr/libexec/dasobjectstore/configure-external-mount-policy ]]; then
  /usr/libexec/dasobjectstore/configure-external-mount-policy || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
  systemctl enable --now dasobjectstored.service dasobjectstore-server.service dasobjectstore-source-access.path || true
  systemctl start dasobjectstore-source-access.service || true
  systemctl restart dasobjectstored.service dasobjectstore-server.service || true
fi

ensure_report_provider
